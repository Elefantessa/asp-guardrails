# ── AWS Bedrock ────────────────────────────────────────────────
# For local dev: leave empty — boto3 reads from ~/.aws/credentials [default]
# For Docker: paste your STS tokens here (never commit real values)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=eu-central-1

# ── Bedrock Models ─────────────────────────────────────────────
BEDROCK_LLM=eu.anthropic.claude-sonnet-4-6
BEDROCK_EMBEDDINGS=amazon.titan-embed-text-v2:0

# ── Embedding Backend ──────────────────────────────────────────
# bedrock → uses Titan Embed v2 (requires AWS credentials)
# huggingface → uses MiniLM locally (no AWS needed)
EMBEDDING_BACKEND=bedrock

# ── Vector Store ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── PostgreSQL ─────────────────────────────────────────────────
# For local dev (infrastructure only via Docker Compose):
DATABASE_URL=postgresql://cloudway:cloudway@localhost:5432/guardrails
# For full Docker deployment (all services in containers):
# DATABASE_URL=postgresql://cloudway:cloudway@postgres:5432/guardrails
USE_POSTGRES_CHECKPOINTER=false

# ── Logging & Audit ────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_PATH=logs/audit.jsonl

# ── Telemetry ──────────────────────────────────────────────────
OTLP_ENDPOINT=http://localhost:4317
