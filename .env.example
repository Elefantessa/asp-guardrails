# ── AWS Bedrock ────────────────────────────────────────────────
# IMPORTANT: Do NOT put temporary STS credentials here.
# Temporary credentials (key starting with ASIA) expire every hour and
# will override ~/.aws/credentials, breaking all Bedrock calls.
# Leave these empty — boto3 will use ~/.aws/credentials [default] automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=eu-central-1
# Profile to use from ~/.aws/credentials (default = [default] section)
AWS_PROFILE=default

# ── Bedrock Models ─────────────────────────────────────────────
# LLM: Claude 3.5 Sonnet v2 — temperature=0 enforced in code
BEDROCK_LLM=anthropic.claude-sonnet-4-6:0
# Embeddings: Titan Embed v2 — no extra API needed
BEDROCK_EMBEDDINGS=amazon.titan-embed-text-v2:0

# ── Vector Store ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── PostgreSQL ─────────────────────────────────────────────────
# Set USE_POSTGRES_CHECKPOINTER=true in production to replace MemorySaver
DATABASE_URL=postgresql://user:pass@localhost:5432/guardrails
USE_POSTGRES_CHECKPOINTER=false

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
